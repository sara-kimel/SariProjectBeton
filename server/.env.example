# קובץ דוגמא להגדרות סביבה
# יש להעתיק את הקובץ הזה לקובץ .env ולעדכן את הערכים בהתאם
# הקובץ הזה מכיל את פרטי החיבור לבסיס הנתונים

# שם השרת של SQL Server (לרוב localhost או שם המחשב\SQLEXPRESS)
DB_SERVER=localhost\SQLEXPRESS

# שם בסיס הנתונים שיצרת
DB_NAME=beton

# שם משתמש לבסיס הנתונים (אם משתמשים ב-Windows Authentication אפשר להשאיר ריק)
DB_USER=

# סיסמא לבסיס הנתונים
DB_PASSWORD=

# האם להשתמש ב-Windows Authentication (True/False)
USE_WINDOWS_AUTH=True

# --- סביבה / הקשחה ---
# סביבת ריצה: development (ברירת מחדל) / production. ב-production השרת יסרב לעלות
# עם JWT_SECRET ריק/ברירת-מחדל/קצר (FIX-4).
APP_ENV=development

# --- אימות / JWT (שלב 1) ---
# מפתח חתימה ל-JWT. בייצור חובה: מחרוזת אקראית ארוכה (32+ תווים), סודית.
# ליצירה: python -c "import secrets; print(secrets.token_urlsafe(48))"
# אל תשאיר ערך קבוע כאן — השאר ריק לפיתוח (תוצג אזהרה) והגדר ערך אמיתי בייצור.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
